# --------------------
# 1. 构建工具目录
# --------------------
**/target/          # Maven 构建输出目录
**/build/           # Gradle 构建输出目录
**/out/             # IDEA 编译输出目录

# --------------------
# 2. 开发工具配置
# --------------------
.idea/              # IntelliJ IDEA 项目配置目录
*.iml               # IntelliJ IDEA 模块文件
*.iws
*.ipr
.classpath
.project
.settings/
.vscode/            # Visual Studio Code 配置

# --------------------
# 3. 编译与打包文件
# --------------------
*.class
*.jar
*.war
*.ear
*.nar
*.zip
*.tar
*.tar.gz
*.rar

# --------------------
# 4. 日志文件
# --------------------
logs/
*.log
*.log.*

# --------------------
# 5. macOS 系统文件
# --------------------
.DS_Store
.AppleDouble
.LSOverride
.Spotlight-V100
.Trashes
__MACOSX/

# --------------------
# 6. 微服务与容器
# --------------------
**/pom.xml.tag
**/pom.xml.releaseBackup
**/pom.xml.versionsBackup
release.properties
**/*.pid          # 服务进程的 PID 文件
**/dump.log       # JVM 堆转储文件
**/*.hprof

# --------------------
# 7. 环境配置与敏感信息
# --------------------
**/application-local.yaml    # 本地配置文件
**/application-*.properties  # 带 profile 的配置文件
.ENV
.env
.envrc
**/secrets/                 # 存放密钥的目录

# --------------------
# 8. 其他临时文件
# --------------------
*.xml
*.tmp
*.temp
*.cache
*.diff
*.patch
*.orig
*.bak
*~
hs_err_pid*
.svn/
*.lock
.flattened-pom.xml          # Maven flatten 插件生成的临时文件
flattened-pom.xml